      "destination": "S4HANACLOUD-my415065",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/opu/odata/sap/API_SALESORGANIZATION_SRV/(.*)$",
      "destination": "S4HANACLOUD-my415065",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/opu/odata/sap/API_DISTRIBUTIONCHANNEL_SRV/(.*)$",
      "destination": "S4HANACLOUD-my415065",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/opu/odata/sap/API_DIVISION_SRV/(.*)$",
      "destination": "S4HANACLOUD-my415065",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/opu/odata/sap/API_BUSINESS_PARTNER/(.*)$",
      "destination": "S4HANACLOUD-my415065",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/opu/odata/sap/API_PRODUCT_SRV/(.*)$",
      "destination": "S4HANACLOUD-my415065",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },    
    {
      "source": "^/resources/(.*)$",
